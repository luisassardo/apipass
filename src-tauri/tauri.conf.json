{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ApiPass",
  "version": "0.4.0",
  "identifier": "com.luisassardo.apipass",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ApiPass",
        "width": 980,
        "height": 760,
        "minWidth": 560,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self'; img-src 'self' data:; connect-src ipc: http://ipc.localhost; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "category": "Utility",
    "shortDescription": "Encrypted vault for API keys",
    "longDescription": "ApiPass keeps your API keys encrypted, organized, and easy to access — fully offline, no backend, no telemetry.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Luis Assardo (LWSXUT3Y4S)",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.15"
    }
  }
}
